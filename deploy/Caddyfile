# Live config on the droplet (/etc/caddy/Caddyfile). Caddy is the single
# front door, dual-hosting both sites with automatic HTTPS:
#   sammysnipes.com -> /var/www/sammysnipes  (built from the schizophrenia repo)
#   nox.church      -> /var/www/nox              (this repo, `make deploy`)
{
	email hanzomain26267@gmail.com
}

sammysnipes.com, www.sammysnipes.com {
	root * /var/www/sammysnipes
	try_files {path} /index.html
	encode gzip
	file_server
}

nox.church, www.nox.church {
	root * /var/www/nox
	encode gzip
	file_server
}
